<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shop_RobloxVipPro</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif}

body{
background:#f3f3f3;
padding-bottom:80px;
}

.header{
background:#fff;
margin:10px;
padding:15px;
border-radius:18px;
display:flex;
justify-content:space-between;
align-items:center;
box-shadow:0 2px 8px rgba(0,0,0,.1);
}

.logo{
font-size:22px;
font-weight:bold;
color:#ff2d55;
}

.menu{
width:55px;
height:55px;
background:#ff2d55;
border-radius:14px;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
color:white;
}

.banner{
margin:10px;
background:white;
padding:10px;
border-radius:18px;
}

.banner img{
width:100%;
border-radius:12px;
}

.nap{
background:white;
margin:10px;
padding:15px;
border-radius:18px;
text-align:center;
}

.bank{
background:#f5f5f5;
padding:10px;
border-radius:10px;
margin-top:10px;
}

.btn{
display:inline-block;
background:#ff2d55;
color:white;
padding:10px 15px;
border:none;
border-radius:10px;
margin-top:10px;
cursor:pointer;
}

.products{
display:grid;
grid-template-columns:1fr 1fr;
gap:10px;
padding:10px;
}

.card{
background:white;
border-radius:18px;
overflow:hidden;
border:2px solid #c84cff;
}

.card img{
width:100%;
height:150px;
object-fit:cover;
}

.card-body{
padding:10px;
text-align:center;
}

.price{
color:red;
font-size:22px;
font-weight:bold;
margin:10px 0;
}

.bottom{
position:fixed;
bottom:0;
left:0;
right:0;
background:white;
display:flex;
justify-content:space-around;
padding:12px;
box-shadow:0 -2px 8px rgba(0,0,0,.1);
}

.bottom a{
text-decoration:none;
color:black;
font-weight:bold;
}
</style>
</head>

<body>

<div class="header">
<div class="logo">SHOP_ROBLOXVIPPRO</div>
<div class="menu">☰</div>
</div>

<div class="banner">
<img src="acc1.webp">
</div>

<div class="nap">
<h2>💳 NẠP TIỀN</h2>

<div class="bank">
Ngân hàng: MB Bank<br>
STK: 123456789<br>
Chủ TK: SHOP_ROBLOXVIPPRO
</div>

<button class="btn" onclick="copySTK()">
Sao chép STK
</button>
</div>

<div class="products">

<div class="card">
<img src="acc1.webp">

<div class="card-body">
<h3>ACC BLOX FRUIT VIP</h3>
<p>Dragon V4</p>
<p>395M Beli</p>

<div class="price">199.000đ</div>

<button class="btn">XEM CHI TIẾT</button>
</div>
</div>

<div class="card">
<img src="acc1.webp">

<div class="card-body">
<h3>ACC BLOX FRUIT MAX</h3>
<p>Godhuman</p>
<p>CDK</p>

<div class="price">299.000đ</div>

<button class="btn">XEM CHI TIẾT</button>
</div>
</div>

</div>

<div class="bottom">
<a href="#">🏠 Trang chủ</a>
<a href="#">🛒 Shop</a>
<a href="#">👤 Tài khoản</a>
</div>

<script>
function copySTK(){
navigator.clipboard.writeText("123456789");
alert("Đã sao chép số tài khoản");
}
</script>

</body>
</html>
